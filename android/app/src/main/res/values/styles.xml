<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash / Launch theme: màn đen trong khi Flutter engine khởi động -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">#0D0D1A</item>
        <item name="android:navigationBarColor">#0D0D1A</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Normal theme: sau khi Flutter đã render frame đầu tiên -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">#0D0D1A</item>
        <item name="android:navigationBarColor">#0D0D1A</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
